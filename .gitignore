# -------------------------------------------------------------------------
# Vivado Generated Directories
# -------------------------------------------------------------------------
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
.Xil/
*_sim_dir/

# -------------------------------------------------------------------------
# Vivado Log and Journal Files
# -------------------------------------------------------------------------
*.jou
*.log
*.str
*.pb
*.wdf

# -------------------------------------------------------------------------
# Generated Hardware & Bitstream Files 
# -------------------------------------------------------------------------
*.bit
*.dcp
*.hdf
*.hwdef
*.bin
*.svf

# -------------------------------------------------------------------------
# OS Specific Hidden Files
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db


# -------------------------------------------------------------------------
# Explicit Overrides (Safety Net)
# -------------------------------------------------------------------------
# Source directory and Vivado project file are NEVER ignored
!source_files/
!*.xpr
!.gitignore