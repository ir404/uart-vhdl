*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
.Xil/
*_sim_dir/

# -------------------------------------------------------------------------
# Vivado Log and Journal Files
# -------------------------------------------------------------------------
*.jou
*.log
*.str
*.pb
*.wdf

# -------------------------------------------------------------------------
# Generated Hardware & Bitstream Files 
# -------------------------------------------------------------------------
*.bit
*.dcp
*.hdf
*.hwdef
*.bin
*.svf

# -------------------------------------------------------------------------
# Vivado Project Files
# -------------------------------------------------------------------------
*.xpr

# -------------------------------------------------------------------------
# OS Specific Hidden Files
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db

# -------------------------------------------------------------------------
# Explicit Overrides (Safety Net - NEVER Ignore These)
# -------------------------------------------------------------------------
# Ensure source code, constraints, and scripts are always tracked
!source_files/
!*.vhd
!*.xdc
!*.tcl
!.gitignore